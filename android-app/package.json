{
  "name": "android-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "copy:web": "powershell -NoProfile -Command \"Copy-Item -Force '..\\vibe-apps\\Choong-Yeok-the-Loyalty-and-Traitor.html' '.\\www\\index.html'; if (Test-Path '.\\www\\assets\\audio') { Remove-Item -Recurse -Force '.\\www\\assets\\audio' }; New-Item -ItemType Directory -Force '.\\www\\assets\\audio' | Out-Null; Copy-Item '..\\vibe-apps\\assets\\audio\\*.mp3' '.\\www\\assets\\audio'\"",
    "cap:copy": "npx cap copy android",
    "cap:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "android:apk:debug": "cd android && gradlew.bat assembleDebug",
    "android:aab:release": "cd android && gradlew.bat bundleRelease",
    "android:setup:sdk": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\setup-android-sdk.ps1 -NonInteractive",
    "android:build:all": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\build-android.ps1",
    "android:build:release": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\build-android.ps1 -ReleaseOnly",
    "android:release:preflight": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\preflight-release.ps1",
    "android:release:package": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\prepare-release-package.ps1",
    "branding:generate": "node .\\scripts\\generate-brand-assets.js"
  },
