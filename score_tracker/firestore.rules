// ============================================================
// Firestore 보안 규칙
// Firebase 콘솔 > Firestore Database > 규칙 탭에 붙여넣기
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 미션/학생 설정: 누구나 읽기, 앱에서 동기화 가능
    // index/admin의 Sheets 동기화 버튼이 이 경로를 직접 갱신함
    match /config/{doc} {
      allow read: if true;
      allow write: if doc in ['missions', 'students'];
    }

    // 점수: 읽기+쓰기 모두 허용 (웹앱이 직접 씀)
    match /scores/{doc} {
      allow read, write: if true;
    }

    // 백업: 읽기+쓰기 모두 허용
    match /backups/{doc} {
      allow read, write: if true;
    }
  }
}
